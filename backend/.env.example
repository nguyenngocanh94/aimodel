APP_NAME=AiModel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=aimodel
DB_USERNAME=aimodel
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# laravel/ai provider configuration (config/ai.php)
# ---------------------------------------------------------------------------
# Active provider: 'fireworks' (default) or 'anthropic'
AI_DEFAULT_PROVIDER=fireworks

# Anthropic provider
ANTHROPIC_API_KEY=

# Fireworks provider (OpenAI-compatible endpoint)
FIREWORKS_API_KEY=
FIREWORKS_URL=https://api.fireworks.ai/inference/v1

# ---------------------------------------------------------------------------
# Skills / sdk-skills configuration (config/skills.php)
# ---------------------------------------------------------------------------
# Discovery mode: "lite" (name+desc only) or "full" (inline instructions)
SKILLS_DISCOVERY_MODE=lite
# Set to true in production to cache skill discovery; leave blank locally
# SKILLS_CACHE_ENABLED=true
# SKILLS_CACHE_STORE=file
# SKILLS_CACHE_TTL=3600
